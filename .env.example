# Configuració opcional de Supabase per variables d'entorn.
# Si es defineixen totes dues, tenen prioritat sobre el selector d'entorn
# (Normal / Test / Pròpia) de la interfície.
VITE_SUPABASE_URL="https://el-teu-projecte.supabase.co"
VITE_SUPABASE_ANON_KEY="la-teva-clau-anon"

# Configuració opcional de Cloudinary (allotjament d'imatges).
# Si no es defineixen, s'utilitzen els valors per defecte del projecte FEM.
VITE_CLOUDINARY_CLOUD="el-teu-cloud-name"
VITE_CLOUDINARY_PRESET="el-teu-upload-preset"
